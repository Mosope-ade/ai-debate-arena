# ── Server configuration ──────────────────────────────────────────────────
# PORT defaults to 3000
PORT=3000

# CORS — restrict which origin the API accepts in production.
# Unset = all cross-origin requests are blocked in production (safe default).
# Set to your frontend URL for shared/public deployments.
# ALLOWED_ORIGIN=https://your-domain.com

# ── Provider API keys (ALL OPTIONAL) ──────────────────────────────────────
# Users can supply their own keys in the browser (Settings → API keys);
# those are sent per-request and never stored on the server.
# Set keys here only if you want the server to provide shared access,
# e.g. for an internal team deployment.

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# MISTRAL_API_KEY=
# OPENROUTER_API_KEY=
